<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ModMetaData>
    <packageId>wishRobber.guildquestsinvanillatab</packageId>
    <name>Isekai Guild Quests in Vanilla Tab</name>
    <author>wishRobber</author>
    <description>Accept Isekai guild quests from the normal Quests tab. Mirrors the Guild Faction Add-on's daily hunt listings into RimWorld's vanilla Quests tab, so you read and accept them without traveling to the world-map board.</description>
    <supportedVersions>
        <li>1.6</li>
    </supportedVersions>
    <modDependencies>
        <li>
            <packageId>brrainz.harmony</packageId>
            <displayName>Harmony</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/2009463077</steamWorkshopUrl>
        </li>
        <li>
            <packageId>JellyCreative.IsekaiLeveling</packageId>
            <displayName>ISEKAI RPG LEVELING</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/3657580708</steamWorkshopUrl>
        </li>
        <li>
            <packageId>Poupun.GuildFactionAddon</packageId>
            <displayName>GUILD FACTION ADD-ON - Isekai RPG Leveling</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/3718568958</steamWorkshopUrl>
        </li>
    </modDependencies>
    <loadAfter>
        <li>brrainz.harmony</li>
        <li>JellyCreative.IsekaiLeveling</li>
        <li>Poupun.GuildFactionAddon</li>
    </loadAfter>
</ModMetaData>
